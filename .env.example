# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_test_guild_id_here

# API Keys
DEEPL_API_KEY=your_deepl_api_key_here
WYNNVENTORY_API_KEY=your_wynnventory_api_key_here

# Environment Settings
NODE_ENV=development
LOG_LEVEL=info

# Cache Configuration
CACHE_TTL=300000
CACHE_MAX_SIZE=1000

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=10

# Database Configuration (for future use)
# DATABASE_URL=your_database_url_here

# Prediction Service Configuration
PREDICTION_UPDATE_INTERVAL=300000
PREDICTION_CONFIDENCE_THRESHOLD=0.7

# Guild Configuration (customize for your guild)
GUILD_NAME=Your Guild Name
GUILD_TAG=TAG

# Admin User Configuration
DISCORD_ADMIN_USERS=your_discord_user_id_here,another_admin_id_here

# Server Configuration
SERVER_PORT=3000
API_TIMEOUT=10000

# MOD API Configuration
MOD_API_PORT=3000
MOD_BOT_TOKEN=your_mod_api_token_here
BOMB_NOTIFICATION_CHANNEL_ID=your_bomb_notification_channel_id_here